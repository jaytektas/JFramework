@PACKAGE_INIT@

# Genesis package config — pulled in by a consumer's find_package(Genesis CONFIG).
# Re-discovers the transitive dependencies the exported targets need, then loads
# the imported targets (Genesis::core, Genesis::platform, ...).

include(CMakeFindDependencyMacro)

# Vulkan is a PUBLIC dependency of Genesis::platform, so the consumer needs it too.
find_dependency(Vulkan)

# Linux windowing / IPC libraries the static platform archive links against.
if(UNIX AND NOT APPLE)
    find_package(PkgConfig REQUIRED)
    pkg_check_modules(XCB         REQUIRED xcb)
    pkg_check_modules(XCB_KEYSYMS REQUIRED xcb-keysyms)
    pkg_check_modules(DBUS        REQUIRED dbus-1)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/JFrameworkTargets.cmake")

check_required_components(JFramework)
